# Porta do servidor (padrão: 3000)
PORT=3000

# Origem permitida por CORS (padrão: * — em produção, libere apenas o domínio
# do app no Lovable, ex.: https://seu-app.lovable.app)
CORS_ORIGIN=*

# TTL do cache do dataset do MOCK em ms (padrão: 60000). Não afeta o Databricks.
DADOS_CACHE_TTL_MS=60000

# ──────────────────────────────────────────────────────────────────────────
# Databricks (fonte de produção). Sem estas variáveis, a API cai no MOCK (dev).
# Defina-as para que /api/abastecimento/resumo calcule sobre a tabela real.
# ──────────────────────────────────────────────────────────────────────────
# Workspace host, SEM https:// (ex.: dbc-xxxxxxxx-xxxx.cloud.databricks.com)
DATABRICKS_HOST=
# Token de acesso (Personal Access Token). É SECRET — nunca comitar.
DATABRICKS_TOKEN=
# ID do SQL Warehouse que executa as consultas.
DATABRICKS_WAREHOUSE_ID=
# Localização da tabela bruta (ver src/databricks/contrato.js).
DATABRICKS_CATALOG=main
DATABRICKS_SCHEMA=abastecimento
DATABRICKS_TABLE=linhas_brutas
# Timeout de espera ativa por consulta, em ms (padrão: 60000).
DATABRICKS_TIMEOUT_MS=60000
